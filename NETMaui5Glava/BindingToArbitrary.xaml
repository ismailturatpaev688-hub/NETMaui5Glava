<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NETMaui5Glava.BindingToArbitrary"
             xmlns:local="clr-namespace:NETMaui5Glava.Controls"
             Title="BindingToArbitrary">

    <!-- INotifyPropertyChanged - привязка к произвольным объектам -->
    <!-- Привязка списков и шаблоны данных (Data Template) -->


    <ContentPage.Resources>
        <ResourceDictionary>
            <x:Array x:Key="Projects" Type="{x:Type local:Project}">
                <local:Project Cost="120" Name="Проект №1" IsActive="True"></local:Project>
                <local:Project Cost="130" Name="Проект №2" IsActive="False"></local:Project>
                <local:Project Cost="140" Name="Проект №3" IsActive="True"></local:Project>
                <local:Project Cost="150" Name="Проект №4" IsActive="True"></local:Project>
                <local:Project Cost="160" Name="Проект №5" IsActive="False"></local:Project>
            </x:Array>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout BindingContext="{StaticResource Projects}" Padding="20" Spacing="20">
            <Label Text="Выберите проект (Picker):" FontSize="Medium" FontAttributes="Bold"></Label>

            <Picker ItemsSource="{Binding}" ItemDisplayBinding="{Binding Name}" Title="Выберите проект"></Picker>

            <BoxView HeightRequest="1" Color="Gray" Margin="0, 10"></BoxView>

            <Label Text="Список проектов (CollectionView):" FontSize="Medium" FontAttributes="Bold"></Label>

            <CollectionView ItemsSource="{Binding}" HeightRequest="300">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="{x:Type local:Project}">
                        <Border Stroke="Gray" StrokeThickness="1" Padding="10" Margin="0,5">
                            <Grid ColumnDefinitions="*, Auto, Auto" RowDefinitions="Auto, Auto">
                                <Label Grid.Column="0" Grid.Row="0" Text="{Binding Name}" FontSize="16" VerticalOptions="Center"></Label>

                                <CheckBox Grid.Column="1" Grid.Row="0" IsChecked="{Binding IsActive}" VerticalOptions="Center" HorizontalOptions="End"></CheckBox>

                                <Label Grid.Column="2" 
                                       Grid.Row="0"
                                       Text="{Binding Cost, StringFormat='{0:C}'}"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End"
                                       Margin="10, 0, 0, 0"></Label>

                                <Label Grid.Column="0"
                                       Grid.ColumnSpan="3"
                                       Grid.Row="1"
                                       Text="{Binding IsActive, Converter={StaticResource BoolToStringConverter}}"
                                       FontSize="12"
                                       TextColor="Gray"></Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>



