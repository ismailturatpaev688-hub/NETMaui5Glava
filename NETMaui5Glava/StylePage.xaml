    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Button" Class="RoundedButton">
                <Style.Setters>
                    <Setter Property="FontSize" Value="14"></Setter>
                    <Setter Property="Padding" Value="5"></Setter>
                    <Setter Property="Margin" Value="5"></Setter>
                    <Setter Property="CornerRadius" Value="15"></Setter>
                    <Setter Property="BackgroundColor" Value="Coral"></Setter>
                    <Setter Property="TextColor" Value="Pink"></Setter>
                </Style.Setters>
            </Style>
            <Style TargetType="Button" Class="SimpleButton">
                <Style.Setters>
                    <Setter Property="FontSize" Value="14"></Setter>
                    <Setter Property="Padding" Value="5"></Setter>
                    <Setter Property="Margin" Value="5"></Setter>
                    <Setter Property="BackgroundColor" Value="LightBlue"></Setter>
                    <Setter Property="TextColor" Value="DarkBlue"></Setter>
                </Style.Setters>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout>
            <Button Text="Кнопка 1" StyleClass="RoundedButton"></Button>
            <Button Text="Кнопка 2" StyleClass="SimpleButton"></Button>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>