<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NETMaui5Glava.SearchPage"
             Title="SearchPage"
             xmlns:controls="clr-namespace:NETMaui5Glava.Controls">
    <Shell.SearchHandler>
        <controls:PageSearchHandler x:Name="Search">
            <controls:PageSearchHandler.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"></Label>
                </DataTemplate>
            </controls:PageSearchHandler.ItemTemplate>
        </controls:PageSearchHandler>
    </Shell.SearchHandler>

    <ContentPage.Resources>
        <ResourceDictionary Source="/Resources/ExampleRes/MyResources.xaml">
        </ResourceDictionary>
        </ContentPage.Resources>

    <!-- ResourcesDictionary - подключение внешних ресурсов -->
    <ScrollView>
        <VerticalStackLayout Padding="30, 0" Spacing="25">
            <Label Text="{StaticResource hello}"></Label>
            <Label Text="{StaticResource hello}" FontSize="{StaticResource size}"></Label>
            <Label Text="{StaticResource hello}" FontSize="{StaticResource size}" TextColor="{StaticResource color}"></Label>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>